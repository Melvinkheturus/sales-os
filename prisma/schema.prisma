// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs are managed in prisma.config.ts (Prisma 7+)
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  ROLE_CHANGED
  ACCOUNT_DEACTIVATED
}

enum NotificationPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum NotificationType {
  LEAD_ASSIGNED
  TASK_DUE
  OVERDUE_ALERT
  MENTION
  SYSTEM
  INVITE
}

enum OnboardingState {
  PLATFORM_SETUP  // first super_admin — must complete platform setup
  PROFILE_SETUP   // all users — must complete personal profile
  COMPLETE        // onboarding done, normal access
}

// ── 1. RBAC Roles ──────────────────────────────
model Role {
  id          String  @id @default(cuid())
  name        String  @unique  // e.g. "super_admin", "admin", "cx_executive", "viewer"
  label       String           // e.g. "Super Admin"
  description String?
  isSystem    Boolean @default(false) // system roles cannot be deleted

  users       User[]
  permissions RolePermission[]
}

// ── 2. RBAC Permissions ─────────────────────────
model Permission {
  id     String @id @default(cuid())
  module String // e.g. "brand", "users", "crm", "settings"
  action String // e.g. "manage", "view", "invite"

  roles  RolePermission[]

  @@unique([module, action])
}

// ── 3. RBAC Role-Permission Pivot ────────────────
model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
}

// ── 4. Brand / Division ─────────────────────────
model Brand {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  color       String?  @default("violet")
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invites    UserInvite[]
  userAccess UserBrandAccess[]
  leads      Lead[]
  sources    LeadSource[]
  stages     LeadStage[]
  clients    Client[]
}

// ── 5. User (Clerk Identity Mapping) ─────────────
model User {
  id               String          @id @default(cuid())
  clerkId          String          @unique
  email            String          @unique
  firstName        String?
  lastName         String?
  username         String?         @unique
  avatarUrl        String?
  designation      String?
  roleId           String
  isActive         Boolean         @default(true)
  onboardingState  OnboardingState @default(PROFILE_SETUP)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  activeBrandId    String?
  theme            String?         @default("system")

  role          Role                    @relation(fields: [roleId], references: [id])
  loginAudits   LoginAudit[]
  notifications Notification[]
  preference    NotificationPreference?
  brandAccess   UserBrandAccess[]
  leadsOwned    Lead[]                  @relation("LeadOwner")
  activities    Activity[]
  meetings      Meeting[]               @relation("MeetingOrganizer")
  clientsManaged Client[]               @relation("EngagementManager")

  @@index([clerkId])
  @@index([roleId])
}

// ── 5a. User ↔ Brand Access Control ──────────────
model UserBrandAccess {
  id        String   @id @default(cuid())
  userId    String
  brandId   String
  grantedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@index([userId])
  @@index([brandId])
}

// ── 6. Invitation System ────────────────────────
model UserInvite {
  id         String       @id @default(cuid())
  email      String
  roleId     String?
  brandId    String
  token      String       @unique
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  invitedBy  String?
  acceptedAt DateTime?
  createdAt  DateTime     @default(now())

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

// ── 7. Compliance Audit Log ─────────────────────
model LoginAudit {
  id        String      @id @default(cuid())
  userId    String?
  email     String
  action    AuditAction
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

// ── 8. Notification MVP ─────────────────────────
model Notification {
  id         String               @id @default(cuid())
  type       NotificationType     @default(SYSTEM)
  priority   NotificationPriority @default(MEDIUM)
  title      String
  message    String
  isRead     Boolean              @default(false)
  link       String?
  userId     String
  createdAt  DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ── 9. Notification Preferences ─────────────────
model NotificationPreference {
  id           String  @id @default(cuid())
  userId       String  @unique
  inAppEnabled Boolean @default(true)
  emailEnabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── 10. CRM Models ──────────────────────────────

model Lead {
  id               String            @id @default(cuid())
  brandId          String
  companyName      String
  contactPerson    String
  email            String?
  phone            String?
  website          String?
  industry         String?
  sourceId         String?
  stageId          String?
  ownerId          String?
  icpScore         Int               @default(0)
  temperature      String            @default("COLD")
  expectedValue    Decimal?
  priority         String            @default("MEDIUM")
  services         String[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Business Review fields
  currentSituation String?
  painPoints       String[]
  opportunityNotes String?

  // BANT fields
  bantBudget       Int               @default(0)
  bantAuthority    Int               @default(0)
  bantNeed         Int               @default(0)
  bantTimeline     Int               @default(0)
  bantScore        Int               @default(0)

  // Win/Loss fields
  winLossStatus    String?
  winLossReason    String?
  winLossNotes     String?

  brand            Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  source           LeadSource?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  stage            LeadStage?        @relation(fields: [stageId], references: [id], onDelete: SetNull)
  owner            User?             @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities       Activity[]
  meetings         Meeting[]
  proposals        Proposal[]

  @@index([brandId])
  @@index([stageId])
  @@index([ownerId])
}

model LeadSource {
  id        String   @id @default(cuid())
  brandId   String
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@unique([brandId, name])
}

model LeadStage {
  id        String   @id @default(cuid())
  brandId   String
  name      String
  label     String
  color     String?
  order     Int      @default(0)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@unique([brandId, name])
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String
  userId      String
  type        String   // "CALL" | "EMAIL" | "WHATSAPP" | "NOTE" | "TASK"
  content     String
  performedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Meeting {
  id          String   @id @default(cuid())
  leadId      String
  organizerId String
  title       String
  scheduledAt DateTime
  duration    Int      @default(30)
  mode        String   // "GOOGLE_MEET" | "ZOOM" | "PHONE" | "IN_PERSON"
  meetingUrl  String?
  summary     String?
  outcome     String?
  status      String   @default("SCHEDULED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organizer   User     @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Proposal {
  id             String    @id @default(cuid())
  leadId         String
  proposalNumber String
  title          String
  status         String    @default("DRAFT")
  sentAt         DateTime?
  value          Decimal
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, proposalNumber])
}

model Client {
  id                  String   @id @default(cuid())
  brandId             String
  companyName         String
  contactPerson       String
  email               String?
  phone               String?
  website             String?
  engagementManagerId String?
  onboardingStatus    String   @default("PENDING")
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  brand               Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  engagementManager   User?    @relation("EngagementManager", fields: [engagementManagerId], references: [id], onDelete: SetNull)

  @@index([brandId])
}
