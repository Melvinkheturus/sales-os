// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs are managed in prisma.config.ts (Prisma 7+)
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  ROLE_CHANGED
  ACCOUNT_DEACTIVATED
}

enum NotificationPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum NotificationType {
  LEAD_ASSIGNED
  TASK_DUE
  OVERDUE_ALERT
  MENTION
  SYSTEM
  INVITE
}

enum OnboardingState {
  PLATFORM_SETUP  // first super_admin — must complete platform setup
  PROFILE_SETUP   // all users — must complete personal profile
  COMPLETE        // onboarding done, normal access
}

// ── 1. RBAC Roles ──────────────────────────────
model Role {
  id          String  @id @default(cuid())
  name        String  @unique  // e.g. "super_admin", "admin", "cx_executive", "viewer"
  label       String           // e.g. "Super Admin"
  description String?
  isSystem    Boolean @default(false) // system roles cannot be deleted

  users       User[]
  permissions RolePermission[]
}

// ── 2. RBAC Permissions ─────────────────────────
model Permission {
  id     String @id @default(cuid())
  module String // e.g. "brand", "users", "crm", "settings"
  action String // e.g. "manage", "view", "invite"

  roles  RolePermission[]

  @@unique([module, action])
}

// ── 3. RBAC Role-Permission Pivot ────────────────
model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
}

// ── 4. Brand / Division ─────────────────────────
model Brand {
  id          String   @id @default(cuid())
  name        String   // e.g. "MergeX", "OVRN Studios", "MergeX Academy"
  slug        String   @unique
  logoUrl     String?
  color       String?  @default("violet")  // accent color token: violet|indigo|rose|amber|emerald|sky
  description String?                      // short workspace description shown on cards
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users     User[]       @relation("BrandUsers")
  invites   UserInvite[]
}

// ── 5. User (Clerk Identity Mapping) ─────────────
model User {
  id               String          @id @default(cuid())
  clerkId          String          @unique
  email            String          @unique
  firstName        String?
  lastName         String?
  username         String?         @unique
  avatarUrl        String?
  designation      String?         // e.g. "CX Executive", "Engagement Manager"
  roleId           String
  isActive         Boolean         @default(true)
  onboardingState  OnboardingState @default(PROFILE_SETUP)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Brand Division Context
  defaultBrandId String?  // Active/default Workspace ID
  brandId        String?
  brand          Brand?   @relation("BrandUsers", fields: [brandId], references: [id], onDelete: SetNull)

  // Workspace preferences
  theme            String?         @default("system")   // "light" | "dark" | "system"

  role          Role                    @relation(fields: [roleId], references: [id])
  loginAudits   LoginAudit[]
  notifications Notification[]
  preference    NotificationPreference?

  @@index([clerkId])
  @@index([roleId])
}

// ── 6. Invitation System ────────────────────────
model UserInvite {
  id         String       @id @default(cuid())
  email      String
  roleId     String?      // Pre-assigned Role ID
  brandId    String       // Pre-assigned target Brand ID
  token      String       @unique
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  invitedBy  String?      // Clerk User ID of inviter
  acceptedAt DateTime?
  createdAt  DateTime     @default(now())

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

// ── 7. Compliance Audit Log ─────────────────────
model LoginAudit {
  id        String      @id @default(cuid())
  userId    String?
  email     String
  action    AuditAction
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

// ── 8. Notification MVP ─────────────────────────
model Notification {
  id         String               @id @default(cuid())
  type       NotificationType     @default(SYSTEM)
  priority   NotificationPriority @default(MEDIUM)
  title      String
  message    String
  isRead     Boolean              @default(false)
  link       String?              // Navigation Target Href
  userId     String
  createdAt  DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ── 9. Notification Preferences ─────────────────
model NotificationPreference {
  id           String  @id @default(cuid())
  userId       String  @unique
  inAppEnabled Boolean @default(true)
  emailEnabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
